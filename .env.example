# ─── Parley Configuration ─────────────────────────────────
# Copy this file to .env and adjust as needed.

# Port the application is accessible on
PARLEY_PORT=8080

# Secret for signing JWT tokens (change this in production!)
JWT_SECRET=parley-dev-secret-change-in-production

# Database (used internally by docker-compose, no need to change for default setup)
# DATABASE_URL=postgresql://parley:parley@db:5432/parley

# ─── Email (SMTP) ─────────────────────────────────────────
# Default points at the bundled MailHog container. The web UI is at
# http://localhost:${MAILHOG_UI_PORT} and shows every email sent by the app.
# In production, point these at your own SMTP server.
MAILHOG_UI_PORT=8025
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=Parley <noreply@parley.local>

# Public URL of the app (used to build links in outgoing emails)
APP_URL=http://localhost:8080
