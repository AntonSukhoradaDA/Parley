# ─── Parley Configuration ─────────────────────────────────
# Copy this file to .env and adjust as needed.

# Port the application is accessible on
PARLEY_PORT=8080

# Secret for signing JWT tokens (change this in production!)
JWT_SECRET=parley-dev-secret-change-in-production

# Database (used internally by docker-compose, no need to change for default setup)
# DATABASE_URL=postgresql://parley:parley@db:5432/parley
