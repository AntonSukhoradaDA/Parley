# ─── Parley Configuration ─────────────────────────────────
# Copy this file to .env and adjust as needed.
#
# For a local try-out, the defaults work as-is — `docker compose up` will
# pick them up. Change JWT_SECRET and SMTP settings before going to prod.

# ─── Web ──────────────────────────────────────────────────
# Port that the client (nginx) listens on (host-side).
PARLEY_PORT=8080

# Public URL of the app. Used in password-reset emails.
APP_URL=http://localhost:8080

# ─── Security ─────────────────────────────────────────────
# Secret used to sign JWT access tokens. MUST be overridden in production.
# Generate one with:
#   openssl rand -hex 48
# or:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=parley-dev-secret-change-in-production

# ─── Database ─────────────────────────────────────────────
# Used internally by docker-compose. Only override if you're pointing at an
# external Postgres.
# DATABASE_URL=postgresql://parley:parley@db:5432/parley

# ─── Email (SMTP) ─────────────────────────────────────────
# Defaults point at the bundled Mailpit container; outgoing mail is captured
# at http://localhost:${MAILHOG_UI_PORT} and never leaves the machine.
# In production, point these at your real SMTP relay.
MAILHOG_UI_PORT=8025
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=Parley <noreply@parley.local>

# ─── File storage ─────────────────────────────────────────
# Directory inside the server container where uploads are written. Mapped to
# the `uploads` Docker volume in docker-compose.yml. No need to change
# unless you're running the server outside Docker.
# FILES_DIR=/var/parley/files
