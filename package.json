{
  "name": "parley",
  "version": "1.0.0",
  "description": "> A classic self-hosted web chat server -- rooms, direct messages, file sharing, and moderation.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test:unit": "cd server && npx jest --testPathPatterns=spec.ts$ --no-coverage --forceExit",
    "test:integration": "cd server && npx jest --config ./test/jest-e2e.json --forceExit --no-coverage",
    "test:e2e": "npx playwright test",
    "test": "npm run test:unit && npm run test:integration"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AntonSukhoradaDA/Parley.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/AntonSukhoradaDA/Parley/issues"
  },
  "homepage": "https://github.com/AntonSukhoradaDA/Parley#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
